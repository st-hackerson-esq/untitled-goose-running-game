{
  "name": "goose-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash -c 'next dev & p1=$!; (cd goose_server && exec mix phx.server) & p2=$!; trap \"kill $p1 $p2 2>/dev/null\" INT TERM EXIT; wait -n; kill $p1 $p2 2>/dev/null; wait'",
    "dev:next": "next dev",
    "dev:phoenix": "cd goose_server && mix phx.server",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "koota": "^0.6.5",
    "next": "16.2.1",
    "phoenix": "^1.8.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "typescript": "^5"
  }
}
